{
  "name": "@just-be/agents",
  "version": "0.1.0",
  "private": false,
  "bin": {
    "agents": "./dist/cli/index.js"
  },
  "workspaces": [
    "agents/*",
    "packages/*"
  ],
  "files": [
    "dist/cli"
  ],
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:cli": "bun build cli/index.ts --target=node --outdir=dist/cli",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@just-be/github-agent": "workspace:*",
    "@just-be/linear-agent": "workspace:*",
    "incur": "^0.3.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260314.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5",
    "wrangler": "^4.67.0"
  },
  "packageManager": "bun@1.3.9"
}
